getgenv().Running = true

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local CollectionService = game:GetService("CollectionService")

local Loader = require(ReplicatedStorage.Packages.Loader)
local ReplicaController = require(Loader.Shared.Utility.ReplicaController)
local BooksData = require(Loader.Shared.Data.Books)

-- Cấu hình an toàn ổn định mạng
local CONFIG = {
    BASE_DELAY = 0.05,     -- Thời gian nghỉ tối thiểu để tránh spam network
    TIMEOUT = 1.5,         -- Thời gian hủy hàng đợi nếu server bị lag quá lâu
    OFFSET_Y = 3.2,        
}

local LibraryReplica = nil
for _, r in pairs(ReplicaController._replicas) do
    if r.Class == "Library" then LibraryReplica = r break end
end
if not LibraryReplica then
    local replicaConnection
    replicaConnection = ReplicaController.ReplicaOfClassCreated("Library", function(replica)
        LibraryReplica = replica
        if replicaConnection then replicaConnection:Disconnect() end
    end)
    while not LibraryReplica do task.wait() end
end

local Library = Workspace:WaitForChild("Library")
local BooksFolder = Library:WaitForChild("Books")
local player = Players.LocalPlayer

-- Fix Camera để mượt mà hơn
player.CameraMode = Enum.CameraMode.Classic
player.CameraMinZoomDistance = 10
task.delay(0.1, function() player.CameraMinZoomDistance = 0.5 end)

local shelfModels = {}
for _, shelfModel in ipairs(CollectionService:GetTagged("Shelf")) do
    shelfModels[shelfModel.Name] = shelfModel
end

local shelfCache = {}

local function getShelfAssignedSeries(shelfId)
    local shelfData = LibraryReplica.Data.Shelves[shelfId]
    if not shelfData then return nil end
    for _, placedBook in pairs(shelfData.Books) do
        local bookName = typeof(placedBook) == "Instance" and placedBook.Name or placedBook
        local seriesName = bookName:match("^(.-)_(.+)$")
        if seriesName then return seriesName end
    end
    return nil
end

local function findShelfForSeries(seriesName, genreName, volumeCount)
    if shelfCache[seriesName] then
        local shelfModel = shelfModels[shelfCache[seriesName]]
        if shelfModel then
            local shelfData = LibraryReplica.Data.Shelves[shelfModel.Name]
            if shelfData and not shelfData.Completed then return shelfModel end
        end
    end

    for shelfId, shelfData in pairs(LibraryReplica.Data.Shelves) do
        if not shelfData.Completed and shelfData.Category == genreName then
            local shelfModel = shelfModels[shelfId]
            if shelfModel and shelfModel:GetAttribute("Width") == volumeCount then
                if getShelfAssignedSeries(shelfId) == seriesName then
                    shelfCache[seriesName] = shelfId
                    return shelfModel
                end
            end
        end
    end

    for shelfId, shelfData in pairs(LibraryReplica.Data.Shelves) do
        if not shelfData.Completed and shelfData.Category == genreName then
            local shelfModel = shelfModels[shelfId]
            if shelfModel and shelfModel:GetAttribute("Width") == volumeCount then
                if not getShelfAssignedSeries(shelfId) and next(shelfData.Books) == nil then
                    shelfCache[seriesName] = shelfId
                    return shelfModel
                end
            end
        end
    end
    return nil
end

local function safeTeleport(targetObj)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or (char:FindFirstChildOfClass("Humanoid") and char:FindFirstChildOfClass("Humanoid").Health <= 0) then return false end
    
    local targetPart = targetObj:IsA("Model") and (targetObj.PrimaryPart or targetObj:FindFirstChildOfClass("BasePart")) or targetObj
    if targetPart then
        root.Velocity = Vector3.new(0, 0, 0)
        root.RotVelocity = Vector3.new(0, 0, 0)
        root.CFrame = CFrame.new(targetPart.Position + Vector3.new(0, CONFIG.OFFSET_Y, 0)) * root.CFrame.Rotation
        return true
    end
    return false
end

-- Hàm thông minh: Chờ đồng bộ dữ liệu từ Replica Server trước khi làm việc tiếp theo
local function awaitReplicaUpdate(shelfName, slotIndex)
    local startTime = os.clock()
    while os.clock() - startTime < CONFIG.TIMEOUT do
        local shelfData = LibraryReplica.Data.Shelves[shelfName]
        if shelfData and shelfData.Books[slotIndex] then
            return true -- Server đã xác nhận đặt sách thành công
        end
        task.wait() -- Đợi frame tiếp theo để kiểm tra lại
    end
    return false -- Quá thời gian chờ (Server bị drop lệnh)
end

-- ==========================================
-- LUỒNG CHẠY THÔNG MINH (ANTI-DESYNC)
-- ==========================================
task.spawn(function()
    while getgenv().Running do
        local rawBooks = BooksFolder:GetChildren()
        if #rawBooks == 0 then 
            task.wait(0.5)
            continue
        end

        local sortedBooks = {}
        for _, book in ipairs(rawBooks) do
            if book:IsA("BasePart") and book.Parent then
                local seriesName, volumeStr = book.Name:match("^(.-)_(.+)$")
                local volumeNum = tonumber(volumeStr)
                if seriesName and volumeNum then
                    if not sortedBooks[seriesName] then sortedBooks[seriesName] = {} end
                    table.insert(sortedBooks[seriesName], {instance = book, volume = volumeNum})
                end
            end
        end

        for seriesName, bookList in pairs(sortedBooks) do
            if not getgenv().Running then break end
            
            local genreName, bookInfo = BooksData.GetCategory(seriesName)
            if not (genreName and bookInfo) then continue end

            table.sort(bookList, function(a, b) return a.volume < b.volume end)

            for _, bookData in ipairs(bookList) do
                if not getgenv().Running then break end
                
                local book = bookData.instance
                local volumeNum = bookData.volume
                
                -- Kiểm tra real-time nếu sách đã bị biến mất
                if not book.Parent then continue end

                local shelfModel = findShelfForSeries(seriesName, genreName, bookInfo.VolumeCount)
                if shelfModel then
                    local shelfName = shelfModel.Name
                    local slotIndex = tostring(volumeNum - 1)
                    local shelfData = LibraryReplica.Data.Shelves[shelfName]
                    
                    if shelfData and not shelfData.Books[slotIndex] then
                        
                        -- Bước 1: Bay tới nhặt sách
                        if safeTeleport(book) then
                            LibraryReplica:FireServer("Grab", book)
                            
                            -- Đợi một nhịp cực ngắn để đảm bảo Character đã chạm trúng hitbox của sách trên server
                            task.wait(CONFIG.BASE_DELAY) 
                            
                            -- Bước 2: Bay tới kệ và đặt sách
                            if safeTeleport(shelfModel) then
                                LibraryReplica:FireServer("Place", shelfModel, volumeNum - 1)
                                
                                -- Thay vì đặt bừa bãi thời gian tĩnh (0.12s), script sẽ đứng đợi 
                                -- cho tới khi Replica báo về là sách đã nằm trên kệ thành công.
                                local success = awaitReplicaUpdate(shelfName, slotIndex)
                                
                                if success then
                                    -- Nếu mạng ngon, nó sẽ làm cuốn tiếp theo NGAY LẬP TỨC không cần chờ.
                                    task.wait(0.02) 
                                else
                                    -- Nếu mạng lag dẫn đến mất lệnh, nghỉ một chút để ổn định lại luồng mạng
                                    task.wait(0.2)
                                end
                            end
                        end
                    end
                end
            end
        end
        task.wait(0.1)
    end
    print("[Auto Library] Đã dừng Farm.")
end)
